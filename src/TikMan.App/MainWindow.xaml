<Window x:Class="TikMan.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TikMan.App.Controls"
        xmlns:loc="clr-namespace:TikMan.App.Localization"
        Title="TikMan" Height="780" Width="1280"
        Icon="pack://application:,,,/TikMan;component/tikman.png" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#F3F3F3" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="6,5">
            <!-- Filter stays top-right; the four groups wrap as whole units: narrow → up to four
                 rows (buttons 1–4 · 5–7 · scan · options), wide → collapse onto one row. -->
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,3,0" Text="🔎"/>
                    <TextBox x:Name="DeviceFilterBox" Width="200" VerticalContentAlignment="Center" Height="24"
                             ToolTip="{loc:Loc Filter_Tip}" TextChanged="DeviceFilterBox_TextChanged"/>
                </StackPanel>

                <WrapPanel Orientation="Horizontal">
                    <!-- Group A: buttons 1–4 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,14,2">
                        <Button Style="{StaticResource ToolButton}" Click="AddDevice_Click" Content="{loc:Loc Tb_Add}"/>
                        <Button Style="{StaticResource ToolButton}" Click="EditDevice_Click" Content="{loc:Loc Tb_Edit}"/>
                        <Button Style="{StaticResource ToolButton}" Click="RemoveDevice_Click" Content="{loc:Loc Tb_Remove}"/>
                        <Separator Margin="6,2" Width="1" Background="#CCCCCC"/>
                        <Button Style="{StaticResource ToolButton}" Click="RefreshAll_Click" Content="{loc:Loc Tb_RefreshAll}"/>
                    </StackPanel>

                    <!-- Group B: buttons 5–7 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,14,2">
                        <Button Style="{StaticResource ToolButton}" Click="BackupAll_Click" Content="{loc:Loc Tb_BackupAll}"/>
                        <Button Style="{StaticResource ToolButton}" FontWeight="SemiBold" Click="InstallUpdates_Click" Content="{loc:Loc Tb_InstallUpdates}"/>
                        <Button Style="{StaticResource ToolButton}" Click="Settings_Click" Content="{loc:Loc Tb_Settings}"/>
                        <Button Click="ReportProblem_Click" Content="{loc:Loc Tb_ReportProblem}" Background="#F68500" Foreground="White"
                                BorderThickness="0" Padding="9,4" Margin="8,0,0,0" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button Click="RequestFeature_Click" Content="{loc:Loc Tb_RequestFeature}" Background="#2266CC" Foreground="White"
                                BorderThickness="0" Padding="9,4" Margin="6,0,0,0" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button x:Name="CoffeeButton" Click="BuyCoffee_Click" Content="{loc:Loc Tb_BuyCoffee}" Background="#7B5233" Foreground="White"
                                BorderThickness="0" Padding="9,4" Margin="6,0,0,0" Cursor="Hand" FontWeight="SemiBold"
                                ToolTip="{loc:Loc Coffee_Title}"/>
                    </StackPanel>

                    <!-- Group C: network discovery -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,14,2">
                        <Button x:Name="ScanButton" Style="{StaticResource ToolButton}" Click="ScanNow_Click" Content="{loc:Loc Tb_Scan}"/>
                        <TextBlock VerticalAlignment="Center" Margin="10,0,4,0" Text="{loc:Loc Sc_Subnet}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBox x:Name="SubnetBox" Width="210" Height="24" VerticalContentAlignment="Center"
                                     ToolTip="{loc:Loc Sc_TargetsTip}"/>
                            <TextBlock x:Name="SubnetSourceText" Foreground="#999999" FontSize="10" Margin="3,1,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button x:Name="CycleAdapterButton" Style="{StaticResource ToolButton}" Click="CycleAdapter_Click"
                                Content="⟳" ToolTip="{loc:Loc Tb_CycleAdapterTip}" Margin="4,0,0,0"/>
                    </StackPanel>

                    <!-- Group D: options -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,2">
                        <CheckBox x:Name="AutoRefreshCheck" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Checked="AutoRefresh_Changed" Unchecked="AutoRefresh_Changed" Content="{loc:Loc Tb_AutoRefresh}"/>
                        <ComboBox x:Name="IntervalCombo" Width="70" VerticalAlignment="Center"
                                  SelectionChanged="IntervalCombo_SelectionChanged">
                            <ComboBoxItem Tag="10">10 s</ComboBoxItem>
                            <ComboBoxItem Tag="30">30 s</ComboBoxItem>
                            <ComboBoxItem Tag="60">60 s</ComboBoxItem>
                            <ComboBoxItem Tag="120">2 min</ComboBoxItem>
                            <ComboBoxItem Tag="300">5 min</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Full-width discovery progress: IPv4/MNDP (0–100 %) and IPv6 (0–15 s). -->
        <Border DockPanel.Dock="Top" x:Name="DiscoveryProgressPanel" Visibility="Collapsed"
                Background="#F7F7F7" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel>
                <DockPanel x:Name="Ipv4ProgressRow">
                    <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="IPv4 / MNDP"/>
                    <ProgressBar x:Name="Ipv4Progress" Height="10" Minimum="0" Maximum="100"/>
                </DockPanel>
                <DockPanel x:Name="Ipv6ProgressRow" Margin="0,4,0,0">
                    <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="IPv6 (15 s)"/>
                    <ProgressBar x:Name="Ipv6Progress" Height="10" Minimum="0" Maximum="15"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <DockPanel LastChildFill="True">
                    <ProgressBar x:Name="MainProgress" DockPanel.Dock="Right" Width="200" Height="12" Margin="8,0,0,0" Visibility="Collapsed"/>
                    <TextBlock x:Name="PublicIpText" DockPanel.Dock="Right" Cursor="Hand" Foreground="#555555" VerticalAlignment="Center"
                               Margin="8,0,0,0" ToolTip="{loc:Loc Pub_Tooltip}" MouseLeftButtonUp="PublicIp_Click"/>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Text="{loc:Loc Status_Ready}"/>
                </DockPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="150"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="300" MinHeight="120"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="DeviceGrid" Grid.Row="0"
                      HorizontalScrollBarVisibility="Auto"
                      RowDetailsVisibilityMode="Collapsed"
                      SelectionChanged="DeviceGrid_SelectionChanged"
                      MouseDoubleClick="DeviceGrid_MouseDoubleClick">
                <DataGrid.Resources>
                    <!-- Centre cell text via ElementStyle (a bare DataGridCell style can disturb row-height
                         measurement, so it's avoided here). -->
                    <Style x:Key="VCenter" TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="DetailsVisibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <!-- Highlight the local default gateway in orange. -->
                            <DataTrigger Binding="{Binding IsGateway}" Value="True">
                                <Setter Property="Background" Value="#F68500"/>
                            </DataTrigger>
                            <!-- Unreachable devices (e.g. stored ones that are gone) get red row text. -->
                            <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                <Setter Property="Foreground" Value="#C0392B"/>
                            </DataTrigger>
                            <!-- The + expander opens the row details (all IPv6 addresses, SMB shares). -->
                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="DetailsVisibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <StackPanel Margin="60,4,8,8" Background="Transparent">
                            <ItemsControl ItemsSource="{Binding Ipv6List}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Margin="0,4,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSmb}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{loc:Loc Sc_SmbHeader}" FontWeight="SemiBold" Foreground="#555555"/>
                                    <TextBlock Text="{Binding SharesStatus}" Foreground="#888888" FontStyle="Italic" Margin="8,0,0,0"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Shares}" Margin="0,4,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}" Click="Share_Click" ToolTip="{Binding UncPath}"
                                                    Margin="0,0,8,4" Padding="8,3"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="30" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.Header>
                            <CheckBox x:Name="MainSelectAll" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Checked="MainSelectAll_Changed" Unchecked="MainSelectAll_Changed"
                                      ToolTip="{loc:Loc Col_MarkAllTip}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="26" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ToggleButton IsChecked="{Binding IsExpanded, UpdateSourceTrigger=PropertyChanged}"
                                              Width="17" Height="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Cursor="Hand" FontSize="12" Padding="0">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Content" Value="+"/>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRowDetails}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content" Value="−"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="30" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="11" Height="11" Fill="{Binding StatusBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                         ToolTip="{Binding StatusText}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_DeviceType}" Binding="{Binding DeviceType}" Width="85" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Name}" Binding="{Binding Name}" Width="170" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn x:Name="Ipv4Column" Header="IPv4" Binding="{Binding Ipv4Address}" Width="130" SortMemberPath="Ipv4SortKey" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn x:Name="Ipv6Column" Header="IPv6" Binding="{Binding Ipv6Summary}" Width="240"
                                        SortMemberPath="Ipv6Display" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTemplateColumn Header="{loc:Loc Col_Protocol}" Width="280" SortMemberPath="TransportDisplay">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding SupportedProtocols}" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Background="{Binding Color}" Margin="0,1,4,1" Padding="5,1"
                                                    ToolTip="{Binding Url}" MouseLeftButtonUp="ProtocolBadge_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsWeb}" Value="True">
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_Mac}" Binding="{Binding Model.MacAddress}" Width="140" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTemplateColumn Header="{loc:Loc Col_MacVendor}" Width="130" SortMemberPath="MacVendor">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding MacVendor}" VerticalAlignment="Center" Padding="4,0">
                                        <TextBlock.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{loc:Loc Ctx_CopyVendorFull}" Click="CopyVendorFull_Click"/>
                                            </ContextMenu>
                                        </TextBlock.ContextMenu>
                                    </TextBlock>
                                    <Button Content="ⓘ" Click="VendorInfo_Click" Cursor="Hand" Padding="2,0" Margin="2,0,0,0"
                                            Background="Transparent" BorderThickness="0" Foreground="#2266CC" FontSize="13"
                                            ToolTip="{loc:Loc Ctx_CopyVendorFull}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MacVendor}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_Vendor}" Binding="{Binding IdentifiedVendor}" Width="100" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Board}" Binding="{Binding ModelDisplay}" Width="130" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Version}" Binding="{Binding Version}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                        <Setter Property="Foreground" Value="#C63B3B"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding VersionIsCurrent}" Value="True">
                                        <Setter Property="Foreground" Value="#2E9E44"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_Latest}" Binding="{Binding LatestWithChannel}" Width="130">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                        <Setter Property="Foreground" Value="#B35900"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_InstalledRel}" Binding="{Binding InstalledReleaseText}" Width="95" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_UpdateRel}" Binding="{Binding UpdateReleaseText}" Width="95" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Cpu}" Binding="{Binding CpuText}" Width="55" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Ram}" Binding="{Binding MemoryText}" Width="120" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Uptime}" Binding="{Binding Uptime}" Width="100" ElementStyle="{StaticResource VCenter}"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" Background="Transparent"/>

            <TabControl Grid.Row="2" DataContext="{Binding SelectedItem, ElementName=DeviceGrid}">
                <TabItem Header="{loc:Loc Tab_Logs}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="4" Background="#FAFAFA">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ToolButton}" Click="RefreshLogs_Click" Content="{loc:Loc Logs_Load}"/>
                                <CheckBox x:Name="LogAutoRefreshCheck" VerticalAlignment="Center" Margin="10,0,0,0" IsChecked="True"
                                          Checked="LogAutoRefresh_Changed" Unchecked="LogAutoRefresh_Changed"
                                          Content="{loc:Loc Logs_Auto}"/>
                                <TextBlock VerticalAlignment="Center" Margin="12,0,4,0" Text="{loc:Loc Logs_Count}"/>
                                <ComboBox x:Name="LogCountCombo" Width="80" SelectedIndex="0">
                                    <ComboBoxItem Tag="100">100</ComboBoxItem>
                                    <ComboBoxItem Tag="500">500</ComboBoxItem>
                                    <ComboBoxItem Tag="0" Content="{loc:Loc Logs_All}"/>
                                </ComboBox>
                                <TextBlock VerticalAlignment="Center" Margin="12,0,4,0" Text="{loc:Loc Logs_Filter}"/>
                                <TextBox x:Name="LogFilterBox" Width="220" VerticalContentAlignment="Center"
                                         TextChanged="LogFilterBox_TextChanged"/>
                            </StackPanel>
                        </Border>
                        <DataGrid ItemsSource="{Binding Logs}" RowHeight="22" FontFamily="Consolas" FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc Col_Time}" Binding="{Binding Time}" Width="150"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Topics}" Binding="{Binding Topics}" Width="180"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Message}" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="{loc:Loc Tab_Monitoring}">
                    <controls:HistoryChart Snapshots="{Binding History}" Margin="4"/>
                </TabItem>

                <TabItem Header="{loc:Loc Tab_Details}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_Connection}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionDisplay}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_User}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Model.Username}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_Mac}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Model.MacAddress}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Upd_Latest}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LatestReleaseText}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Upd_Channel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UpdateChannel}"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_Notes}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Model.Notes}" TextWrapping="Wrap"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Style="{StaticResource ToolButton}" Click="EditDevice_Click" Content="{loc:Loc Det_Edit}"/>
                            <Button Style="{StaticResource ToolButton}" Click="BackupSingle_Click" Content="{loc:Loc Det_BackupRsc}"/>
                            <Button Style="{StaticResource ToolButton}" Click="BinaryBackupSingle_Click" Content="{loc:Loc Det_BackupFull}"/>
                            <Button Click="OpenFirmwarePage_Click" Content="{loc:Loc Det_FirmwarePage}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTpLink}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#777777" MaxWidth="620" HorizontalAlignment="Left"
                                   Text="{loc:Loc Det_BackupDesc}"/>

                        <ItemsControl ItemsSource="{Binding ExtraInfo}" Margin="0,12,0,0">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasExtraInfo}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <TextBlock Text="{Binding Key}" FontWeight="SemiBold" Foreground="#555555" Width="160"/>
                                        <TextBlock Text="{Binding Value}" TextWrapping="Wrap" MaxWidth="460"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Margin="0,14,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSmb}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{loc:Loc Sc_SmbHeader}" FontWeight="SemiBold" Foreground="#555555"/>
                                <TextBlock Text="{Binding SharesStatus}" Foreground="#888888" FontStyle="Italic" Margin="8,0,0,0"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Shares}" Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}" Click="Share_Click" ToolTip="{Binding UncPath}"
                                                Margin="0,0,8,4" Padding="8,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{loc:Loc Tab_Available}">
                    <DataGrid ItemsSource="{Binding AvailableUpdates}" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" HeadersVisibility="Column" Margin="4">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Loc Upd_Channel}" Binding="{Binding Channel}" Width="160"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Version}" Binding="{Binding Version}" Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                <Setter Property="Foreground" Value="#2E9E44"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{loc:Loc Col_UpdateRel}" Binding="{Binding ReleaseDate}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="{loc:Loc Col_LastError}">
                    <TextBox Text="{Binding LastError, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Foreground="#A03030" BorderThickness="0"
                             Background="Transparent" Margin="6" FontFamily="Consolas" FontSize="12"/>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
