<Window x:Class="TikMan.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TikMan.App.Controls"
        xmlns:loc="clr-namespace:TikMan.App.Localization"
        Title="TikMan" Height="780" Width="1280"
        Icon="pack://application:,,,/TikMan;component/tikman.png" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#F3F3F3" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="6,5">
            <!-- Two flowing rows: the right-hand group stays docked right, the tool buttons wrap
                 to a second line when the window gets too narrow, so nothing overlaps. -->
            <DockPanel>
                <WrapPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,3,0" Text="🔎"/>
                    <TextBox x:Name="DeviceFilterBox" Width="160" VerticalContentAlignment="Center" Height="24" Margin="0,0,8,0"
                             ToolTip="{loc:Loc Filter_Tip}" TextChanged="DeviceFilterBox_TextChanged"/>
                    <Button Style="{StaticResource ToolButton}" Click="Settings_Click" Content="{loc:Loc Tb_Settings}"/>
                    <Separator Margin="6,2" Width="1" Background="#CCCCCC"/>
                    <CheckBox x:Name="AutoRefreshCheck" VerticalAlignment="Center" Margin="0,0,8,0"
                              Checked="AutoRefresh_Changed" Unchecked="AutoRefresh_Changed" Content="{loc:Loc Tb_AutoRefresh}"/>
                    <ComboBox x:Name="IntervalCombo" Width="70" VerticalAlignment="Center"
                              SelectionChanged="IntervalCombo_SelectionChanged">
                        <ComboBoxItem Tag="10">10 s</ComboBoxItem>
                        <ComboBoxItem Tag="30">30 s</ComboBoxItem>
                        <ComboBoxItem Tag="60">60 s</ComboBoxItem>
                        <ComboBoxItem Tag="120">2 min</ComboBoxItem>
                        <ComboBoxItem Tag="300">5 min</ComboBoxItem>
                    </ComboBox>
                </WrapPanel>
                <WrapPanel Orientation="Horizontal">
                    <Button Style="{StaticResource ToolButton}" Click="Scan_Click" Content="{loc:Loc Tb_Scan}"/>
                    <Button Style="{StaticResource ToolButton}" Click="AddDevice_Click" Content="{loc:Loc Tb_Add}"/>
                    <Button Style="{StaticResource ToolButton}" Click="EditDevice_Click" Content="{loc:Loc Tb_Edit}"/>
                    <Button Style="{StaticResource ToolButton}" Click="RemoveDevice_Click" Content="{loc:Loc Tb_Remove}"/>
                    <Separator Margin="6,2" Width="1" Background="#CCCCCC"/>
                    <Button Style="{StaticResource ToolButton}" Click="RefreshAll_Click" Content="{loc:Loc Tb_RefreshAll}"/>
                    <Button Style="{StaticResource ToolButton}" Click="BackupAll_Click" Content="{loc:Loc Tb_BackupAll}"/>
                    <Button Style="{StaticResource ToolButton}" FontWeight="SemiBold" Click="InstallUpdates_Click" Content="{loc:Loc Tb_InstallUpdates}"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="{loc:Loc Status_Ready}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="MainProgress" Width="200" Height="12" Visibility="Collapsed"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="150"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="300" MinHeight="120"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="DeviceGrid" Grid.Row="0"
                      SelectionChanged="DeviceGrid_SelectionChanged"
                      MouseDoubleClick="DeviceGrid_MouseDoubleClick">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <!-- Highlight the local default gateway in orange. -->
                            <DataTrigger Binding="{Binding IsGateway}" Value="True">
                                <Setter Property="Background" Value="#F68500"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="30" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.Header>
                            <CheckBox x:Name="MainSelectAll" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Checked="MainSelectAll_Changed" Unchecked="MainSelectAll_Changed"
                                      ToolTip="{loc:Loc Col_MarkAllTip}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="30" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="11" Height="11" Fill="{Binding StatusBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                         ToolTip="{Binding StatusText}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_Name}" Binding="{Binding Name}" Width="170"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Address}" Binding="{Binding Host}" Width="120"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Protocol}" Binding="{Binding TransportDisplay}" Width="70"/>
                    <DataGridTemplateColumn Header="{loc:Loc Col_Vendor}" Width="100" SortMemberPath="Vendor">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Vendor}" VerticalAlignment="Center" Padding="4,0">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{loc:Loc Ctx_CopyVendorFull}" Click="CopyVendorFull_Click"/>
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_Board}" Binding="{Binding Board}" Width="130"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Version}" Binding="{Binding Version}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                        <Setter Property="Foreground" Value="#C63B3B"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding VersionIsCurrent}" Value="True">
                                        <Setter Property="Foreground" Value="#2E9E44"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_Latest}" Binding="{Binding LatestWithChannel}" Width="130">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                        <Setter Property="Foreground" Value="#B35900"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_InstalledRel}" Binding="{Binding InstalledReleaseText}" Width="95"/>
                    <DataGridTextColumn Header="{loc:Loc Col_UpdateRel}" Binding="{Binding UpdateReleaseText}" Width="95"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Cpu}" Binding="{Binding CpuText}" Width="55"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Ram}" Binding="{Binding MemoryText}" Width="120"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Uptime}" Binding="{Binding Uptime}" Width="100"/>
                    <DataGridTextColumn Header="{loc:Loc Col_LastError}" Binding="{Binding LastError}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#A03030"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="ToolTip" Value="{Binding LastError}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" Background="Transparent"/>

            <TabControl Grid.Row="2" DataContext="{Binding SelectedItem, ElementName=DeviceGrid}">
                <TabItem Header="{loc:Loc Tab_Logs}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="4" Background="#FAFAFA">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ToolButton}" Click="RefreshLogs_Click" Content="{loc:Loc Logs_Load}"/>
                                <CheckBox x:Name="LogAutoRefreshCheck" VerticalAlignment="Center" Margin="10,0,0,0" IsChecked="True"
                                          Checked="LogAutoRefresh_Changed" Unchecked="LogAutoRefresh_Changed"
                                          Content="{loc:Loc Logs_Auto}"/>
                                <TextBlock VerticalAlignment="Center" Margin="12,0,4,0" Text="{loc:Loc Logs_Count}"/>
                                <ComboBox x:Name="LogCountCombo" Width="80" SelectedIndex="0">
                                    <ComboBoxItem Tag="100">100</ComboBoxItem>
                                    <ComboBoxItem Tag="500">500</ComboBoxItem>
                                    <ComboBoxItem Tag="0" Content="{loc:Loc Logs_All}"/>
                                </ComboBox>
                                <TextBlock VerticalAlignment="Center" Margin="12,0,4,0" Text="{loc:Loc Logs_Filter}"/>
                                <TextBox x:Name="LogFilterBox" Width="220" VerticalContentAlignment="Center"
                                         TextChanged="LogFilterBox_TextChanged"/>
                            </StackPanel>
                        </Border>
                        <DataGrid ItemsSource="{Binding Logs}" RowHeight="22" FontFamily="Consolas" FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc Col_Time}" Binding="{Binding Time}" Width="150"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Topics}" Binding="{Binding Topics}" Width="180"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Message}" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="{loc:Loc Tab_Monitoring}">
                    <controls:HistoryChart Snapshots="{Binding History}" Margin="4"/>
                </TabItem>

                <TabItem Header="{loc:Loc Tab_Details}">
                    <StackPanel Margin="12" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_Connection}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionDisplay}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_User}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Model.Username}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_Mac}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Model.MacAddress}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Upd_Latest}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LatestReleaseText}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Upd_Channel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UpdateChannel}"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_Notes}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Model.Notes}" TextWrapping="Wrap"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Style="{StaticResource ToolButton}" Click="EditDevice_Click" Content="{loc:Loc Det_Edit}"/>
                            <Button Style="{StaticResource ToolButton}" Click="BackupSingle_Click" Content="{loc:Loc Det_BackupRsc}"/>
                            <Button Style="{StaticResource ToolButton}" Click="BinaryBackupSingle_Click" Content="{loc:Loc Det_BackupFull}"/>
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#777777" MaxWidth="620" HorizontalAlignment="Left"
                                   Text="{loc:Loc Det_BackupDesc}"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
