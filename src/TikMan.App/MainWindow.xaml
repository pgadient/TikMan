<Window x:Class="TikMan.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TikMan.App.Controls"
        xmlns:loc="clr-namespace:TikMan.App.Localization"
        Title="TikMan" Height="780" Width="1280"
        Icon="pack://application:,,,/TikMan;component/tikman.png" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid>
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#F9F9F9" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="2,1">
            <MenuItem Header="{loc:Loc Menu_File}">
                <MenuItem Header="{loc:Loc Tb_Settings}" Click="Settings_Click"/>
                <Separator/>
                <MenuItem Header="{loc:Loc Menu_Export}">
                    <MenuItem Header="{loc:Loc Exp_Ipv4Csv}" Click="ExportIpv4Csv_Click"/>
                    <MenuItem Header="{loc:Loc Exp_Ipv4Html}" Click="ExportIpv4Html_Click"/>
                    <Separator/>
                    <MenuItem Header="{loc:Loc Exp_Ipv6Csv}" Click="ExportIpv6Csv_Click"/>
                    <MenuItem Header="{loc:Loc Exp_Ipv6Html}" Click="ExportIpv6Html_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{loc:Loc Menu_Actions}">
                <MenuItem Header="{loc:Loc Tb_InstallUpdates}" Click="InstallUpdates_Click"/>
            </MenuItem>
            <MenuItem Header="{loc:Loc Menu_View}">
                <MenuItem x:Name="ContactButtonsMenuItem" Header="{loc:Loc Menu_ContactButtons}"
                          IsCheckable="True" IsChecked="True" Click="ContactButtons_Toggled"/>
                <MenuItem x:Name="ListInfoMenuItem" Header="{loc:Loc Menu_ListInfo}"
                          IsCheckable="True" IsChecked="True" Click="ListInfo_Toggled"/>
            </MenuItem>
        </Menu>
        <Border DockPanel.Dock="Top" Background="#F3F3F3" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="6,5">
            <!-- Row 1: scan + device actions left, coloured contact buttons right (one shared
                 vertical axis). Row 2: filter + auto-refresh. -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                <StackPanel x:Name="ContactButtonsPanel" DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Stretch" Margin="10,0,0,0">
                    <Button x:Name="ReportProblemButton" Style="{StaticResource ToolButton}" Click="ReportProblem_Click" Content="{loc:Loc Tb_ReportProblem}"
                            Background="#F68500" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
                    <Button x:Name="RequestFeatureButton" Style="{StaticResource ToolButton}" Click="RequestFeature_Click" Content="{loc:Loc Tb_RequestFeature}"
                            Background="#2266CC" Foreground="White" BorderThickness="0" Margin="6,0,0,0" Cursor="Hand" FontWeight="SemiBold"/>
                    <Button x:Name="CoffeeButton" Style="{StaticResource ToolButton}" Click="BuyCoffee_Click" Content="{loc:Loc Tb_BuyCoffee}"
                            Background="#7B5233" Foreground="White" BorderThickness="0" Margin="6,0,0,0" Cursor="Hand" FontWeight="SemiBold"
                            ToolTip="{loc:Loc Coffee_Title}"/>
                </StackPanel>

                <WrapPanel Orientation="Horizontal">
                    <!-- Group A: network discovery – the most important part, so it comes first. -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch" Margin="0,2,14,2">
                        <Button x:Name="ScanButton" Style="{StaticResource ToolButton}" FontWeight="SemiBold"
                                Click="ScanNow_Click" Content="{loc:Loc Tb_Scan}"/>
                        <Button x:Name="CycleAdapterButton" Style="{StaticResource ToolButton}" Click="CycleAdapter_Click"
                                Content="⏭" ToolTip="{loc:Loc Tb_CycleAdapterTip}" Margin="4,0,0,0"/>
                        <TextBlock VerticalAlignment="Center" Margin="10,0,4,0" Text="{loc:Loc Sc_Subnet}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBox x:Name="SubnetBox" Width="210" Height="24" VerticalContentAlignment="Center"
                                     ToolTip="{loc:Loc Sc_TargetsTip}" PreviewKeyDown="SubnetBox_PreviewKeyDown"/>
                            <TextBlock x:Name="SubnetSourceText" Foreground="#999999" FontSize="10" Margin="3,1,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Group B: device actions -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch" Margin="0,2,14,2">
                        <Button Style="{StaticResource ToolButton}" Click="SetLogin_Click" Content="{loc:Loc Tb_SetCreds}"/>
                        <Button Style="{StaticResource ToolButton}" Click="ClearAll_Click" Content="{loc:Loc Tb_Clear}"/>
                        <Separator Margin="6,2" Width="1" Background="#CCCCCC"/>
                        <Button Style="{StaticResource ToolButton}" Click="WakeManual_Click" Content="{loc:Loc Tb_Wake}"
                                ToolTip="{loc:Loc Wol_Prompt}"/>
                    </StackPanel>

                </WrapPanel>
                </DockPanel>

                <!-- Row 2: list-tips ⓘ (instant hover tooltip, no click), the list filter, auto-refresh. -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock x:Name="ListInfoIcon" Text="ⓘ" Foreground="#2266CC" FontSize="18" FontWeight="Bold"
                               Margin="0,0,10,0" VerticalAlignment="Center" Cursor="Help"
                               ToolTip="{loc:Loc List_InfoTip}"
                               ToolTipService.InitialShowDelay="0" ToolTipService.BetweenShowDelay="0"
                               ToolTipService.ShowDuration="60000"/>
                    <TextBlock VerticalAlignment="Center" Margin="0,0,4,0" Text="{loc:Loc Filter_Label}"/>
                    <TextBox x:Name="DeviceFilterBox" Width="200" VerticalContentAlignment="Center" Height="24"
                             ToolTip="{loc:Loc Filter_Tip}" TextChanged="DeviceFilterBox_TextChanged"
                             PreviewKeyDown="DeviceFilterBox_PreviewKeyDown"/>
                    <TextBlock x:Name="FilterSpinner" Text="⏳" VerticalAlignment="Center" Margin="4,0,0,0" Visibility="Collapsed"/>
                    <CheckBox x:Name="AutoRefreshCheck" VerticalAlignment="Center" Margin="16,0,8,0"
                              Checked="AutoRefresh_Changed" Unchecked="AutoRefresh_Changed" Content="{loc:Loc Tb_AutoRefresh}"/>
                    <ComboBox x:Name="IntervalCombo" Width="70" VerticalAlignment="Center"
                              SelectionChanged="IntervalCombo_SelectionChanged">
                        <ComboBoxItem Tag="10">10 s</ComboBoxItem>
                        <ComboBoxItem Tag="30">30 s</ComboBoxItem>
                        <ComboBoxItem Tag="60">60 s</ComboBoxItem>
                        <ComboBoxItem Tag="120">2 min</ComboBoxItem>
                        <ComboBoxItem Tag="300">5 min</ComboBoxItem>
                    </ComboBox>
                    <CheckBox x:Name="ContinuousScanCheck" VerticalAlignment="Center" Margin="16,0,0,0"
                              Checked="ContinuousScan_Changed" Unchecked="ContinuousScan_Changed"
                              Content="{loc:Loc Tb_ContinuousScan}" ToolTip="{loc:Loc Tb_ContinuousScanTip}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Full-width discovery progress: scans first (IPv4, MNDP, IPv6), then the meta phases
             collect details about the devices just found (a stable base before analysis). -->
        <Border DockPanel.Dock="Top" x:Name="DiscoveryProgressPanel" Visibility="Collapsed"
                Background="#F7F7F7" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel>
                <!-- One bar for everything (the default): the phases run in parallel and each on its own
                     clock, so a single bar showing how far the whole scan has come is easier to read
                     than seven. Switch it off in the settings to watch each phase separately. -->
                <DockPanel x:Name="CombinedProgressRow" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666"
                               Text="{loc:Loc Prog_All}"/>
                    <ProgressBar x:Name="CombinedProgress" Height="10" Minimum="0" Maximum="100"/>
                </DockPanel>

                <StackPanel x:Name="PhaseRows">
                    <DockPanel x:Name="Ipv4ProgressRow">
                        <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="IPv4 Scan"/>
                        <ProgressBar x:Name="Ipv4Progress" Height="10" Minimum="0" Maximum="100"/>
                    </DockPanel>
                    <DockPanel x:Name="MndpProgressRow" Margin="0,4,0,0">
                        <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="MNDP (5 s)"/>
                        <ProgressBar x:Name="MndpProgress" Height="10" Minimum="0" Maximum="5"/>
                    </DockPanel>
                    <DockPanel x:Name="ZonProgressRow" Margin="0,4,0,0" Visibility="Collapsed">
                        <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="Zyxel ZON (5 s)"/>
                        <ProgressBar x:Name="ZonProgress" Height="10" Minimum="0" Maximum="5"/>
                    </DockPanel>
                    <DockPanel x:Name="Ipv4MetaProgressRow" Margin="0,4,0,0">
                        <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="IPv4 Meta"/>
                        <ProgressBar x:Name="Ipv4MetaProgress" Height="10" Minimum="0" Maximum="100"/>
                    </DockPanel>
                    <DockPanel x:Name="MdnsProgressRow" Margin="0,4,0,0" Visibility="Collapsed">
                        <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="mDNS (4 s)"/>
                        <ProgressBar x:Name="MdnsProgress" Height="10" Minimum="0" Maximum="4"/>
                    </DockPanel>
                    <DockPanel x:Name="SsdpProgressRow" Margin="0,4,0,0" Visibility="Collapsed">
                        <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="UPnP/SSDP (4 s)"/>
                        <ProgressBar x:Name="SsdpProgress" Height="10" Minimum="0" Maximum="4"/>
                    </DockPanel>
                    <DockPanel x:Name="Ipv6ProgressRow" Margin="0,4,0,0">
                        <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="IPv6 Scan (15 s)"/>
                        <ProgressBar x:Name="Ipv6Progress" Height="10" Minimum="0" Maximum="15"/>
                    </DockPanel>
                    <DockPanel x:Name="Ipv6MetaProgressRow" Margin="0,4,0,0">
                        <TextBlock DockPanel.Dock="Left" Width="120" VerticalAlignment="Center" Foreground="#666666" Text="IPv6 Meta"/>
                        <ProgressBar x:Name="Ipv6MetaProgress" Height="10" Minimum="0" Maximum="100"/>
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <DockPanel LastChildFill="True">
                    <ProgressBar x:Name="MainProgress" DockPanel.Dock="Right" Width="200" Height="12" Margin="8,0,0,0" Visibility="Collapsed"/>
                    <TextBlock x:Name="PublicIpText" DockPanel.Dock="Right" Cursor="Hand" Foreground="#555555" VerticalAlignment="Center"
                               Margin="8,0,0,0" ToolTip="{loc:Loc Pub_Tooltip}" MouseLeftButtonUp="PublicIp_Click"/>
                    <!-- Shown only when Npcap is missing: some features (Zyxel ZON) then can't run. -->
                    <TextBlock x:Name="NpcapWarnText" DockPanel.Dock="Right" Cursor="Hand" Foreground="#B36B00" FontSize="11"
                               VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed"
                               ToolTip="{loc:Loc Npcap_WarnTip}" Text="{loc:Loc Npcap_Warn}" MouseLeftButtonUp="NpcapWarn_Click"/>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Text="{loc:Loc Status_Ready}"/>
                </DockPanel>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="150"/>
                <RowDefinition x:Name="SplitterRow" Height="6"/>
                <RowDefinition x:Name="DetailRow" Height="300" MinHeight="120"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <!-- IPv4/IPv6 view switch: same device list, only the address column and sorting flip.
                     The list hints (multi-select, gateway highlight) live on the ⓘ button up in the toolbar. -->
                <DockPanel DockPanel.Dock="Top">
                    <TabControl x:Name="AddressTabs" BorderThickness="0" Padding="0"
                                Background="Transparent" SelectionChanged="AddressTabs_SelectionChanged">
                        <TabItem Header="IPv4"/>
                        <TabItem Header="IPv6"/>
                        <TabItem Header="{loc:Loc Tab_Topology}"/>
                        <TabItem Header="{loc:Loc Tab_TopoPhys}"/>
                        <TabItem Header="{loc:Loc Tab_Backup}"/>
                    </TabControl>
                </DockPanel>
                <TextBlock x:Name="DeviceCountText" DockPanel.Dock="Bottom" Foreground="#666666" FontSize="11"
                           Margin="4,3,0,0"/>

            <!-- The device list and the topology map share this space; the third tab swaps which one is
                 shown. They must sit in a Grid together: as siblings in the DockPanel, the first of them
                 gets docked to the left edge and is left with a sliver of the width. -->
            <Grid>
            <DataGrid x:Name="DeviceGrid"
                      HorizontalScrollBarVisibility="Auto"
                      RowDetailsVisibilityMode="Collapsed"
                      SelectionMode="Extended"
                      LoadingRow="DeviceGrid_LoadingRow"
                      SelectionChanged="DeviceGrid_SelectionChanged"
                      MouseDoubleClick="DeviceGrid_MouseDoubleClick"
                      PreviewMouseLeftButtonDown="DeviceGrid_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="DeviceGrid_PreviewMouseMove"
                      PreviewMouseLeftButtonUp="DeviceGrid_PreviewMouseLeftButtonUp">
                <DataGrid.Resources>
                    <!-- Centre cell text via ElementStyle (a bare DataGridCell style can disturb row-height
                         measurement, so it's avoided here). -->
                    <Style x:Key="VCenter" TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{loc:Loc Ctx_SetCredsSel}" Click="SetLogin_Click" FontWeight="SemiBold"/>
                        <MenuItem Header="{loc:Loc Ctx_SshTerminal}" Click="ContextSsh_Click"/>
                        <MenuItem Header="{loc:Loc Ctx_OpenWinScp}" Click="OpenWinScp_Click"/>
                        <MenuItem Header="{loc:Loc Ctx_WakeOnLan}" Click="WakeDevice_Click"/>
                        <Separator/>
                        <MenuItem Header="{loc:Loc Tb_Remove}" Click="RemoveDevice_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <!-- Group colour of the IPv6 view (transparent in the IPv4 view). -->
                        <Setter Property="Background" Value="{Binding RowBackground}"/>
                        <Style.Triggers>
                            <!-- Highlight the local default gateway in orange. -->
                            <DataTrigger Binding="{Binding IsGateway}" Value="True">
                                <Setter Property="Background" Value="#F68500"/>
                            </DataTrigger>
                            <!-- Unreachable devices (e.g. stored ones that are gone) get red row text. -->
                            <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                <Setter Property="Foreground" Value="#C0392B"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <StackPanel Margin="60,4,8,8" Background="Transparent">
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Ipv6Rest.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{loc:Loc Det_MoreIpv6}" FontWeight="SemiBold" Foreground="#555555"/>
                                <ItemsControl ItemsSource="{Binding Ipv6Rest}" Margin="0,2,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FirmwareDetails.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{loc:Loc Det_Firmware}" FontWeight="SemiBold" Foreground="#555555"/>
                                <ItemsControl ItemsSource="{Binding FirmwareDetails}" Margin="0,2,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Margin="0,4,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSmb}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{loc:Loc Sc_SmbHeader}" FontWeight="SemiBold" Foreground="#555555"/>
                                    <TextBlock Text="{Binding SharesStatus}" Foreground="#888888" FontStyle="Italic" Margin="8,0,0,0"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Shares}" Margin="0,4,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}" Click="Share_Click" ToolTip="{Binding UncPath}"
                                                    Margin="0,0,8,4" Padding="8,3"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="26" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ToggleButton IsChecked="{Binding IsExpanded, UpdateSourceTrigger=PropertyChanged}"
                                              Checked="Expander_Toggled" Unchecked="Expander_Toggled"
                                              Width="17" Height="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Cursor="Hand" FontSize="12" Padding="0">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Content" Value="+"/>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasRowDetails}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content" Value="−"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="30" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="11" Height="11" Fill="{Binding StatusBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                         ToolTip="{Binding StatusText}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="Ipv6GroupColumn" Header="{loc:Loc Col_Group}" Binding="{Binding Group}"
                                        SortMemberPath="GroupSortKey" Width="Auto" MaxWidth="80" Visibility="Collapsed"
                                        ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_DeviceType}" Binding="{Binding DeviceType}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Name}" Binding="{Binding Name}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn x:Name="Ipv4Column" Header="IPv4" Binding="{Binding Ipv4Address}" Width="Auto" MaxWidth="1000" SortMemberPath="Ipv4SortKey" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn x:Name="Ipv6Column" Header="IPv6" Binding="{Binding Ipv6Summary}" Width="Auto" MaxWidth="1000"
                                        SortMemberPath="Ipv6Display" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTemplateColumn Header="{loc:Loc Col_Protocol}" Width="Auto" MaxWidth="1000" SortMemberPath="TransportDisplay">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding SupportedProtocols}" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Background="{Binding Color}" Margin="0,1,4,1" Padding="5,1"
                                                    ToolTip="{Binding Tooltip}" MouseLeftButtonUp="ProtocolBadge_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsClickable}" Value="True">
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_Mac}" Binding="{Binding Model.MacAddress}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTemplateColumn Header="{loc:Loc Col_MacVendor}" Width="Auto" MaxWidth="1000" SortMemberPath="MacVendor">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding MacVendor}" VerticalAlignment="Center" Padding="4,0">
                                        <TextBlock.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{loc:Loc Ctx_CopyVendorFull}" Click="CopyVendorFull_Click"/>
                                            </ContextMenu>
                                        </TextBlock.ContextMenu>
                                    </TextBlock>
                                    <Button Content="ⓘ" Click="VendorInfo_Click" Cursor="Hand" Padding="2,0" Margin="2,0,0,0"
                                            Background="Transparent" BorderThickness="0" Foreground="#2266CC" FontSize="13"
                                            ToolTip="{loc:Loc Ctx_CopyVendorFull}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MacVendor}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_Vendor}" Binding="{Binding IdentifiedVendor}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Board}" Binding="{Binding ModelDisplay}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Serial}" Binding="{Binding SerialNumber}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Os}" Binding="{Binding OsDisplay}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Version}" Binding="{Binding Version}" Width="Auto" MaxWidth="1000">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                        <Setter Property="Foreground" Value="#C63B3B"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding VersionIsCurrent}" Value="True">
                                        <Setter Property="Foreground" Value="#2E9E44"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_Latest}" Binding="{Binding LatestWithChannel}" Width="Auto" MaxWidth="1000">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                        <Setter Property="Foreground" Value="#B35900"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{loc:Loc Col_InstalledRel}" Binding="{Binding InstalledReleaseText}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_UpdateRel}" Binding="{Binding UpdateReleaseText}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Cpu}" Binding="{Binding CpuText}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Ram}" Binding="{Binding MemoryText}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                    <DataGridTextColumn Header="{loc:Loc Col_Uptime}" Binding="{Binding Uptime}" Width="Auto" MaxWidth="1000" ElementStyle="{StaticResource VCenter}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Topology map. Pan/zoom is handled on this Border, not on the Canvas: the Canvas carries
                 the pan/zoom transform, so its own hit area moves with it and it stops receiving the
                 very events that move it. The Border stays put and always sees the mouse. -->
            <Border x:Name="TopologyHost" Visibility="Collapsed" Background="#FBFCFD"
                    BorderBrush="#DDDDDD" BorderThickness="1" ClipToBounds="True" Focusable="True"
                    MouseLeftButtonDown="Topology_BackgroundDown"
                    MouseMove="Topology_MouseMove"
                    MouseLeftButtonUp="Topology_MouseUp"
                    MouseWheel="Topology_MouseWheel">
                <Grid>
                    <Canvas x:Name="TopologyCanvas" Background="Transparent" IsHitTestVisible="True">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="TopologyScale" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="TopologyPan" X="0" Y="0"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                    </Canvas>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                Margin="8">
                        <Button Content="{loc:Loc Topo_Relayout}" Click="Topology_Relayout_Click" Padding="8,3"
                                Margin="0,0,6,0"/>
                        <Button Content="{loc:Loc Topo_Fit}" Click="Topology_Fit_Click" Padding="8,3"/>
                        <TextBlock x:Name="TopologyHint" VerticalAlignment="Center" Margin="10,0,0,0"
                                   Foreground="#888888" FontSize="11" Text="{loc:Loc Topo_Hint}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Backup tab: the backup actions that used to live in the title menu. Single-device
                 backups stay on the device's details tab, where the device context already is. -->
            <Border x:Name="BackupHost" Visibility="Collapsed" Background="#FBFCFD"
                    BorderBrush="#DDDDDD" BorderThickness="1" Padding="18">
                <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock FontWeight="SemiBold" FontSize="15" Text="{loc:Loc Tab_Backup}"/>
                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#555555"
                               Text="{loc:Loc Det_BackupDesc}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Style="{StaticResource ToolButton}" Click="BackupAll_Click"
                                Content="{loc:Loc Tb_BackupAll}"/>
                    </StackPanel>
                    <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#777777" FontSize="11"
                               Text="{loc:Loc Bak_SingleHint}"/>
                </StackPanel>
            </Border>
            </Grid>
            </DockPanel>

            <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" Background="Transparent"/>

            <TabControl x:Name="DetailTabs" Grid.Row="2">
                <TabItem Header="{loc:Loc Tab_Logs}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="4" Background="#FAFAFA">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource ToolButton}" Click="RefreshLogs_Click" Content="{loc:Loc Logs_Load}"/>
                                <CheckBox x:Name="LogAutoRefreshCheck" VerticalAlignment="Center" Margin="10,0,0,0" IsChecked="True"
                                          Checked="LogAutoRefresh_Changed" Unchecked="LogAutoRefresh_Changed"
                                          Content="{loc:Loc Logs_Auto}"/>
                                <TextBlock VerticalAlignment="Center" Margin="12,0,4,0" Text="{loc:Loc Logs_Count}"/>
                                <ComboBox x:Name="LogCountCombo" Width="80" SelectedIndex="0">
                                    <ComboBoxItem Tag="100">100</ComboBoxItem>
                                    <ComboBoxItem Tag="500">500</ComboBoxItem>
                                    <ComboBoxItem Tag="0" Content="{loc:Loc Logs_All}"/>
                                </ComboBox>
                                <TextBlock VerticalAlignment="Center" Margin="12,0,4,0" Text="{loc:Loc Logs_Filter}"/>
                                <TextBox x:Name="LogFilterBox" Width="220" VerticalContentAlignment="Center"
                                         TextChanged="LogFilterBox_TextChanged"/>
                            </StackPanel>
                        </Border>
                        <DataGrid ItemsSource="{Binding Logs}" RowHeight="22" FontFamily="Consolas" FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc Col_Time}" Binding="{Binding Time}" Width="150"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Topics}" Binding="{Binding Topics}" Width="180"/>
                                <DataGridTextColumn Header="{loc:Loc Col_Message}" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="{loc:Loc Tab_Monitoring}">
                    <controls:HistoryChart Snapshots="{Binding History}" Margin="4"/>
                </TabItem>

                <TabItem Header="{loc:Loc Tab_Details}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                                <RowDefinition Height="26"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_Connection}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionDisplay}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_User}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Model.Username}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_Mac}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Model.MacAddress}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Upd_Latest}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LatestReleaseText}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Upd_Channel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UpdateChannel}"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" FontWeight="SemiBold" Text="{loc:Loc Det_Notes}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Model.Notes}" TextWrapping="Wrap"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Style="{StaticResource ToolButton}" Click="SetLogin_Click" Content="{loc:Loc Det_Edit}"/>
                            <Button Style="{StaticResource ToolButton}" Click="BackupSingle_Click" Content="{loc:Loc Det_BackupRsc}"/>
                            <Button Style="{StaticResource ToolButton}" Click="BinaryBackupSingle_Click" Content="{loc:Loc Det_BackupFull}"/>
                            <Button Click="OpenFirmwarePage_Click" Content="{loc:Loc Det_FirmwarePage}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ToolButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTpLink}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#777777" MaxWidth="620" HorizontalAlignment="Left"
                                   Text="{loc:Loc Det_BackupDesc}"/>

                        <ItemsControl ItemsSource="{Binding ExtraInfo}" Margin="0,12,0,0">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasExtraInfo}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <TextBlock Text="{Binding Key}" FontWeight="SemiBold" Foreground="#555555" Width="160"/>
                                        <TextBlock Text="{Binding Value}" TextWrapping="Wrap" MaxWidth="460"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Margin="0,14,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSmb}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{loc:Loc Sc_SmbHeader}" FontWeight="SemiBold" Foreground="#555555"/>
                                <TextBlock Text="{Binding SharesStatus}" Foreground="#888888" FontStyle="Italic" Margin="8,0,0,0"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Shares}" Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}" Click="Share_Click" ToolTip="{Binding UncPath}"
                                                Margin="0,0,8,4" Padding="8,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{loc:Loc Tab_Available}">
                    <DataGrid ItemsSource="{Binding AvailableUpdates}" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" HeadersVisibility="Column" Margin="4">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Loc Upd_Channel}" Binding="{Binding Channel}" Width="160"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Version}" Binding="{Binding Version}" Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                <Setter Property="Foreground" Value="#2E9E44"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{loc:Loc Col_UpdateRel}" Binding="{Binding ReleaseDate}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="{loc:Loc Col_LastError}">
                    <TextBox Text="{Binding LastError, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Foreground="#A03030" BorderThickness="0"
                             Background="Transparent" Margin="6" FontFamily="Consolas" FontSize="12"/>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>

    <!-- Copy confirmation toast (bottom centre, fades out; big enough to actually read). -->
    <Border x:Name="CopyToast" Visibility="Collapsed" IsHitTestVisible="False"
            HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="24,0,24,56"
            Background="#E62D2D2D" CornerRadius="8" Padding="20,12">
        <TextBlock x:Name="CopyToastText" Foreground="White" FontSize="15" FontWeight="SemiBold"
                   MaxWidth="760" TextTrimming="CharacterEllipsis"/>
    </Border>
    </Grid>
</Window>
