<Window x:Class="TikMan.App.DeviceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TikMan.App.Localization"
        Title="{loc:Loc De_TitleEdit}" Width="420" SizeToContent="Height" Icon="pack://application:,,,/TikMan;component/tikman.png"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock x:Name="MultiBanner" Visibility="Collapsed" TextWrapping="Wrap" Margin="0,0,0,10"
                   FontWeight="SemiBold" Foreground="#B35900" Text="{loc:Loc De_MultiBanner}"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="RowAddress" Height="34"/>
                <RowDefinition Height="34"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{loc:Loc De_Address}"/>
            <TextBox x:Name="HostBox" Grid.Row="0" Grid.Column="1" VerticalContentAlignment="Center" Height="26"/>

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{loc:Loc De_User}"/>
            <TextBox x:Name="UserBox" Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center" Height="26" Text="admin"/>

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{loc:Loc De_Password}"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="2" Grid.Column="1" VerticalContentAlignment="Center" Height="26"/>
        </Grid>

        <TextBlock x:Name="PasswordHint" Foreground="#777777" FontSize="11" Margin="120,4,0,0"
                   Text="{loc:Loc De_PwHint}" Visibility="Collapsed"/>
        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#777777" FontSize="11" Text="{loc:Loc De_ConnAutoHint}"/>

        <TextBlock x:Name="TestResultText" Margin="0,10,0,0" TextWrapping="Wrap" MinHeight="18"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="TestButton" Padding="10,5" Margin="0,0,8,0" Click="Test_Click" Content="{loc:Loc De_Test}"/>
            <Button Padding="14,5" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click" Content="{loc:Loc De_Ok}"/>
            <Button Padding="14,5" IsCancel="True" Content="{loc:Loc De_Cancel}"/>
        </StackPanel>
    </StackPanel>
</Window>
