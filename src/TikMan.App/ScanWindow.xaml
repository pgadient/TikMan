<Window x:Class="TikMan.App.ScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TikMan.App.Localization"
        Title="{loc:Loc Sc_Title}" Height="600" Width="880" Icon="pack://application:,,,/TikMan;component/tikman.png"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <DockPanel Margin="10">
        <Border DockPanel.Dock="Bottom" Background="#F7F7F7" BorderBrush="#DDDDDD" BorderThickness="1" Padding="8" Margin="0,8,0,0" CornerRadius="3">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#777777"
                           TextWrapping="Wrap" Text="{loc:Loc Sc_CredsHint}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="AddButton" Padding="14,6" FontWeight="SemiBold" Click="Add_Click" Content="{loc:Loc Sc_AddSelected}"/>
                    <Button Padding="14,6" Margin="8,0,0,0" IsCancel="True" Content="{loc:Loc Sc_Close}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl>
            <!-- ================= IPv4 ================= -->
            <TabItem Header="IPv4">
                <DockPanel Margin="4">
                    <Border DockPanel.Dock="Top" Background="#F7F7F7" BorderBrush="#DDDDDD" BorderThickness="1" Padding="8" CornerRadius="3">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="MndpButton" Padding="10,5" Click="Mndp_Click" Content="{loc:Loc Sc_Mndp}"/>
                                <TextBlock VerticalAlignment="Center" Margin="20,0,6,0" Text="{loc:Loc Sc_Subnet}"/>
                                <TextBox x:Name="SubnetBox" Width="230" VerticalContentAlignment="Center" Height="26"
                                         ToolTip="{loc:Loc Sc_TargetsTip}"/>
                                <Button x:Name="ScanButton" Padding="10,5" Margin="8,0,0,0" Click="ScanSubnet_Click" Content="{loc:Loc Sc_ScanBtn}"/>
                                <Button x:Name="StopButton" Padding="10,5" Margin="8,0,0,0" IsEnabled="False" Click="Stop_Click" Content="{loc:Loc Sc_Stop}"/>
                                <Button x:Name="ClearButton" Padding="10,5" Margin="8,0,0,0" Click="Clear_Click" Content="{loc:Loc Sc_Clear}"/>
                            </StackPanel>
                            <ProgressBar x:Name="ScanProgress" Height="6" Margin="0,8,0,0" Visibility="Collapsed"/>
                            <TextBlock x:Name="ScanStatusText" Margin="0,6,0,0" Foreground="#666666" Text="{loc:Loc Sc_Intro}"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="ResultGrid" Margin="0,8,0,0" MouseDoubleClick="Result_MouseDoubleClick"
                              SelectionChanged="ResultGrid_SelectionChanged" RowDetailsVisibilityMode="VisibleWhenSelected">
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Margin="36,2,0,6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSmb}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{loc:Loc Sc_SmbHeader}" FontWeight="SemiBold" Foreground="#555555"/>
                                            <TextBlock Text="{Binding SharesStatus}" Foreground="#888888" FontStyle="Italic" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding Shares}" Margin="0,4,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Name}" Click="Share_Click" ToolTip="{Binding UncPath}"
                                                            Margin="0,0,8,4" Padding="8,3"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="34" CanUserSort="False">
                                <DataGridTemplateColumn.Header>
                                    <CheckBox x:Name="ScanSelectAll" HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="True"
                                              Checked="ScanSelectAll_Changed" Unchecked="ScanSelectAll_Changed"
                                              ToolTip="{loc:Loc Col_MarkAllTip}"/>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding CanSelect}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{loc:Loc Col_Ip}" Binding="{Binding IpAddress}" Width="120"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Identity}" Binding="{Binding Identity}" Width="160"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Mac}" Binding="{Binding MacAddress}" Width="130"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Vendor}" Binding="{Binding Vendor}" Width="100"/>
                            <DataGridTextColumn Header="{loc:Loc Col_DeviceType}" Binding="{Binding DeviceType}" Width="85"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Board}" Binding="{Binding Board}" Width="120"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Version}" Binding="{Binding Version}" Width="90"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Source}" Binding="{Binding Source}" Width="60"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Services}" Binding="{Binding Services}" Width="200"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Hint}" Binding="{Binding Hint}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ================= IPv6 ================= -->
            <TabItem Header="IPv6">
                <DockPanel Margin="4">
                    <Border DockPanel.Dock="Top" Background="#F7F7F7" BorderBrush="#DDDDDD" BorderThickness="1" Padding="8" CornerRadius="3">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="Ipv6Button" Padding="10,5" Click="Ipv6Discover_Click" Content="{loc:Loc Sc_Ipv6Discover}"/>
                                <Button x:Name="Ipv6ClearButton" Padding="10,5" Margin="8,0,0,0" Click="Ipv6Clear_Click" Content="{loc:Loc Sc_Clear}"/>
                            </StackPanel>
                            <ProgressBar x:Name="Ipv6Progress" Height="6" Margin="0,8,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
                            <TextBlock x:Name="Ipv6StatusText" Margin="0,6,0,0" Foreground="#666666" Text="{loc:Loc Sc_Ipv6Intro}"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="ResultGridV6" Margin="0,8,0,0" MouseDoubleClick="Result_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="34" CanUserSort="False">
                                <DataGridTemplateColumn.Header>
                                    <CheckBox x:Name="ScanSelectAllV6" HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="True"
                                              Checked="ScanSelectAllV6_Changed" Unchecked="ScanSelectAllV6_Changed"
                                              ToolTip="{loc:Loc Col_MarkAllTip}"/>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding CanSelect}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{loc:Loc Col_Ip}" Binding="{Binding IpAddress}" Width="300"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Mac}" Binding="{Binding MacAddress}" Width="150"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Vendor}" Binding="{Binding Vendor}" Width="140"/>
                            <DataGridTextColumn Header="{loc:Loc Col_DeviceType}" Binding="{Binding DeviceType}" Width="85"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Source}" Binding="{Binding Source}" Width="60"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Hint}" Binding="{Binding Hint}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
