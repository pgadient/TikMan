<UserControl x:Class="TikMan.App.BackupAllView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:TikMan.App.Localization">
    <Grid>
        <DockPanel Margin="10">
            <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="#555555" Text="{loc:Loc Ba_Hint}"/>

            <Border DockPanel.Dock="Top" Padding="0,8,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Foreground="#555555" Margin="0,0,10,0"
                               Text="{loc:Loc Ba_TypesLabel}"/>
                    <CheckBox x:Name="ConfigCheck" IsChecked="True" VerticalAlignment="Center"
                              Checked="BackupType_Changed" Unchecked="BackupType_Changed"
                              Content="{loc:Loc Ba_TypeConfig}"/>
                    <CheckBox x:Name="BinaryCheck" IsChecked="True" VerticalAlignment="Center" Margin="16,0,0,0"
                              Checked="BackupType_Changed" Unchecked="BackupType_Changed"
                              Content="{loc:Loc Ba_TypeBinary}"/>
                </StackPanel>
            </Border>

            <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
                <DockPanel>
                    <!-- No "choose folder" button and no folder to remember: Start asks every time. For
                         a tool that writes files, confirming where they go beats silently reusing the
                         folder you picked an hour ago. The path shows here while the run goes. -->
                    <TextBlock x:Name="FolderText" DockPanel.Dock="Left" VerticalAlignment="Center"
                               Foreground="#777777" TextTrimming="CharacterEllipsis" MaxWidth="460"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="StartButton" Padding="16,6" FontWeight="SemiBold" Click="Start_Click" Content="{loc:Loc Ua_Start}"/>
                        <Button x:Name="StopButton" Padding="16,6" Margin="8,0,0,0" IsEnabled="False" Click="Stop_Click" Content="{loc:Loc Ua_Stop}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="ItemGrid" Grid.Column="0" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="34">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding CanSelect}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{loc:Loc Col_DeviceType}" Binding="{Binding Device.DeviceType}" Width="110"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Vendor}" Binding="{Binding Device.IdentifiedVendor}" Width="110"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Device}" Binding="{Binding Device.Name}" Width="180"/>
                            <DataGridTextColumn Header="{loc:Loc Col_Address}" Binding="{Binding Device.Host}" Width="130"/>
                            <DataGridTextColumn Header="{loc:Loc Col_State}" Binding="{Binding StateText}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Top">
                        <Button x:Name="UpButton" Padding="8,4" Click="MoveUp_Click">▲</Button>
                        <Button x:Name="DownButton" Padding="8,4" Margin="0,4,0,0" Click="MoveDown_Click">▼</Button>
                    </StackPanel>
                </Grid>

                <ProgressBar x:Name="BackupProgress" Grid.Row="1" Height="12" Margin="0,8,0,0" Visibility="Collapsed"/>

                <TextBox x:Name="LogBox" Grid.Row="2" Margin="0,8,0,0" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" Background="#FBFBFB"/>
            </Grid>
        </DockPanel>

        <!-- Backups need credentials, so with no login stored anywhere there is nothing to list. As a
             tab this is a state we sit in, not a dialog we refuse to open – so it says so in place. -->
        <Border x:Name="EmptyHint" Visibility="Collapsed" Background="#FBFCFD">
            <TextBlock Text="{loc:Loc Msg_NoBackupCandidates}" TextWrapping="Wrap" MaxWidth="420"
                       Foreground="#666666" HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
