<Window x:Class="TikMan.App.BackupAllWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TikMan.App.Localization"
        Title="{loc:Loc Ba_Title}" Height="600" Width="780" Icon="pack://application:,,,/TikMan;component/tikman.png"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Closing="Window_Closing">
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="#555555" Text="{loc:Loc Ba_Hint}"/>

        <Border DockPanel.Dock="Top" Padding="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="AlsoBinaryCheck" VerticalAlignment="Center" Content="{loc:Loc Ba_AlsoBinary}"/>
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#777777" Text="{loc:Loc Ba_AlsoBinaryHint}"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button x:Name="FolderButton" Padding="12,5" Click="ChooseFolder_Click" Content="{loc:Loc Ba_ChooseFolder}"/>
                    <TextBlock x:Name="FolderText" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#777777"
                               TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="StartButton" Padding="16,6" FontWeight="SemiBold" Click="Start_Click" Content="{loc:Loc Ua_Start}"/>
                    <Button x:Name="StopButton" Padding="16,6" Margin="8,0,0,0" IsEnabled="False" Click="Stop_Click" Content="{loc:Loc Ua_Stop}"/>
                    <Button x:Name="CloseButton" Padding="16,6" Margin="8,0,0,0" IsCancel="True" Content="{loc:Loc Ua_Close}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="ItemGrid" Grid.Column="0" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="34">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding CanSelect}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{loc:Loc Col_Device}" Binding="{Binding Device.Name}" Width="180"/>
                        <DataGridTextColumn Header="{loc:Loc Col_Address}" Binding="{Binding Device.Host}" Width="130"/>
                        <DataGridTextColumn Header="{loc:Loc Col_DeviceType}" Binding="{Binding Device.DeviceType}" Width="110"/>
                        <DataGridTextColumn Header="{loc:Loc Col_State}" Binding="{Binding StateText}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Top">
                    <Button x:Name="UpButton" Padding="8,4" Click="MoveUp_Click">▲</Button>
                    <Button x:Name="DownButton" Padding="8,4" Margin="0,4,0,0" Click="MoveDown_Click">▼</Button>
                </StackPanel>
            </Grid>

            <ProgressBar x:Name="BackupProgress" Grid.Row="1" Height="12" Margin="0,8,0,0" Visibility="Collapsed"/>

            <TextBox x:Name="LogBox" Grid.Row="2" Margin="0,8,0,0" IsReadOnly="True"
                     FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" Background="#FBFBFB"/>
        </Grid>
    </DockPanel>
</Window>
