<Window x:Class="TikMan.App.VendorInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TikMan.App.Localization"
        Title="{loc:Loc Vi_Title}" Width="440" SizeToContent="Height"
        Icon="pack://application:,,,/TikMan;component/tikman.png"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="14">
        <TextBox x:Name="EntryBox" IsReadOnly="True" AcceptsReturn="True" Height="150"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{loc:Loc Vi_Copy}" Padding="12,5" Margin="0,0,8,0" Click="Copy_Click"/>
            <Button Content="{loc:Loc De_Ok}" Padding="14,5" IsDefault="True" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
