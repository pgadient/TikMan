<Application x:Class="TikMan.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#2D6CB5"/>
        <SolidColorBrush x:Key="OnlineBrush" Color="#2E9E44"/>
        <SolidColorBrush x:Key="OfflineBrush" Color="#C63B3B"/>
        <SolidColorBrush x:Key="BusyBrush" Color="#D98E1F"/>
        <SolidColorBrush x:Key="UnknownBrush" Color="#9A9A9A"/>

        <!-- Toolbar buttons stretch to the full row height, so they all share one size. -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>

        <!-- Selection is per row everywhere in TikMan, but clicking still drew a focus rectangle around
             the single cell you hit – faint, and marking something no action here works on. BasedOn
             keeps the theme's template: dropping it is what makes a DataGridCell style disturb row
             heights. Applied via the DataGrid style below, so every grid gets it. -->
        <Style x:Key="NoCellFocus" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="CellStyle" Value="{StaticResource NoCellFocus}"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E4E4E4"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="26"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Application.Resources>
</Application>
