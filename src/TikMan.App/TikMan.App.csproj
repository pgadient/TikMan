<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>TikMan</AssemblyName>
    <RootNamespace>TikMan.App</RootNamespace>
    <ApplicationIcon>tikman.ico</ApplicationIcon>
    <!-- Build number auto-increments: 1.1.<days since 2026-01-01> (recomputed on every build). -->
    <Version>1.3.12</Version>
    <Product>TikMan</Product>
    <Company>Pascal Montico-Gadient</Company>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\TikMan.Core\TikMan.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="tikman.png" />
  </ItemGroup>

</Project>
